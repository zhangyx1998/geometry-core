{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "outDir": "dist"
  },
  "include": ["src", "types"],
  "exclude": ["src/**/*.test.ts", "test.setup.ts", "docs", "dist", "node_modules"]
}
